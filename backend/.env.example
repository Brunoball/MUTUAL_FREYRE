APP_ENV=local
APP_DEBUG=true
APP_TIMEZONE=America/Argentina/Cordoba
APP_URL=http://localhost:3001
ALLOWED_ORIGINS=http://localhost:3000

# Base principal: negocio financiero y administrativo.
DB_HOST=localhost
DB_PORT=3306
DB_NAME=mutual_freyre
DB_USER=root
DB_PASS=

# Base central de identidad. Si host/puerto/usuario/clave quedan vacíos,
# el backend reutiliza los valores DB_* de arriba.
AUTH_DB_HOST=localhost
AUTH_DB_PORT=3306
AUTH_DB_NAME=mutual_identidad
AUTH_DB_USER=root
AUTH_DB_PASS=
AUTH_APPLICATION_CODE=backoffice

# Cada aplicación futura debe usar un nombre de cookie diferente.
# Ejemplos: mutual_online_session, mutual_wallet_session, mutual_comercios_session.
SESSION_COOKIE_NAME=mutual_session
SESSION_COOKIE_PATH=/
SESSION_COOKIE_DOMAIN=
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=Lax
SESSION_ABSOLUTE_HOURS=12
SESSION_IDLE_MINUTES=120
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCK_MINUTES=15
